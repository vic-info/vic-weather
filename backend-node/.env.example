DATABASE_URL=postgresql://username@host:5432/databricks_postgres?sslmode=require
# Option A: refresh Lakebase credentials automatically with the Databricks CLI.
DATABRICKS_PROFILE=weather-course
LAKEBASE_ENDPOINT=projects/vic-weather-db/branches/production/endpoints/primary
# Option B: omit the two settings above and paste the one-hour OAuth token.
# PGPASSWORD=replace-with-copy-oauth-token
PORT=3000
